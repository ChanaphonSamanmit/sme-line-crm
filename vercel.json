{
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": ["app/**"]
      }
    }
  ],
  "routes": [
    { "src": "/admin", "dest": "/static/admin/index.html" },
    { "src": "/liff",  "dest": "/static/liff/index.html" },
    { "src": "/(.*)",  "dest": "/api/index.py" }
  ]
}
